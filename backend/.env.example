# BS Detector — environment configuration.
# Copy to `.env` at the repo root (docker compose reads it there):
#   cp backend/.env.example .env   # then set OPENAI_API_KEY
# Every value below except OPENAI_API_KEY is OPTIONAL — the app falls back to the
# documented default, and a malformed numeric override is ignored (logged) rather
# than crashing at import.

# --- Required ---
# Your OpenAI API key. Use a DEDICATED key with a low billing cap: this repo runs
# third-party scaffold code in a sandbox (see docs/SECURITY.md).
OPENAI_API_KEY=your-api-key-here

# --- Optional (model) ---
# Model for all structured-output agents. A reasoning model with strong legal
# reasoning + structured-output support. Override to pin a snapshot or fall back.
STRUCTURED_MODEL=gpt-5.5

# Max completion tokens per structured call. Sized for the worst-case extraction
# (every authority + every finding with reasoning); raise it for a larger corpus.
# A truncated parse raises a typed error and degrades that agent, not the whole run.
STRUCTURED_MAX_TOKENS=8000

# --- Optional (orchestration) ---
# Per-agent timeout in seconds. 120s fits a GPT-5.5 reasoning call with chain-of-
# thought over the full case file (measured ~50-90s). Bounds EACH agent; the fan-out
# agents run concurrently, the memo runs sequentially after them.
AGENT_TIMEOUT_SECONDS=120
